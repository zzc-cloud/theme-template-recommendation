# Theme Template Recommendation 本体层环境配置
#
# 使用方式：
# 1. 复制此文件为 .env
# 2. 填写实际的数据库连接信息
# 3. 运行脚本时自动加载

# ============== MySQL 配置 ==============
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=chatbi_metadata

# ============== Neo4j 配置 ==============
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Neo4j 配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# SiliconFlow API 配置（用于向量嵌入 + LLM 推理）
SILICONFLOW_API_KEY=sk-your-api-key-here

# 向量库路径（可选，默认使用 mcp-server/data/indicators_vector）
CHROMA_PATH=/path/to/chroma

# LLM 模型配置（⚠️ 必填，不可依赖默认值）
LLM_MODEL=Pro/zai-org/GLM-5
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Agent 行为参数（可选）
MAX_ITERATION_ROUNDS=3
CONVERGENCE_SIMILARITY_THRESHOLD=0.80
LOW_CONFIDENCE_THRESHOLD=0.60
DEFAULT_TOP_K_THEMES=3
DEFAULT_TOP_K_TEMPLATES=5
VECTOR_SEARCH_TOP_K=20

# 并发控制配置（可选）
MAX_CONCURRENT_REQUESTS=10
CONCURRENT_TIMEOUT_SECONDS=5.0

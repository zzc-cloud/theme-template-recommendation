# ============================================
# Docker 构建排除文件
# ============================================

# ─────────────────────────────────────────────
# 文档类（不影响程序运行）
# ─────────────────────────────────────────────
*.md
*.mdx
LICENSE
NOTICE
CHANGELOG*
HISTORY*
CHANGES*

# ─────────────────────────────────────────────
# 开发/测试文件
# ─────────────────────────────────────────────
tests/
__tests__/
test_*.py
*_test.py
conftest.py
pytest.ini
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ─────────────────────────────────────────────
# IDE/编辑器配置
# ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-*

# ─────────────────────────────────────────────
# Git
# ─────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ─────────────────────────────────────────────
# Python 虚拟环境和缓存
# ─────────────────────────────────────────────
venv/
.venv/
env/
.env
env.bak/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ─────────────────────────────────────────────
# 本地数据和配置
# ─────────────────────────────────────────────
*.log
*.log.*
logs/
data/
*.db
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────
# Node.js（如果有）
# ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ─────────────────────────────────────────────
# Docker 相关（在镜像中不需要）
# ─────────────────────────────────────────────
docker-compose*.yml
Dockerfile*
.dockerignore
.docker/

# ─────────────────────────────────────────────
# 临时文件和脚本
# ─────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.backup
*.sh

# ─────────────────────────────────────────────
# 部署相关文档
# ─────────────────────────────────────────────
deploy/
deployment/
docs/deploy*
docs/api*

# ─────────────────────────────────────────────
# 其他非必要文件
# ─────────────────────────────────────────────
*.bak
*.swp
*.swo
.cache/
.mypy_cache/
.ruff_cache/

# ============================================
# Theme Template Recommendation - 生产环境配置
# 路径：/opt/theme-template/.env
# 用途：docker run --env-file /opt/theme-template/.env
# ============================================

# ─────────────────────────────────────────────
# Neo4j 图数据库配置
# ─────────────────────────────────────────────
# Neo4j 连接地址（内网部署时用 172.17.0.1 指向宿主机）
NEO4J_URI=bolt://172.17.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=你的Neo4j密码

# ─────────────────────────────────────────────
# SiliconFlow API 配置（分离）
# ─────────────────────────────────────────────

# Embedding API Key（用于向量搜索）
SILICONFLOW_EMBEDDING_API_KEY=sk-你的Embedding密钥

# LLM API Key（用于大模型推理）
SILICONFLOW_LLM_API_KEY=sk-你的LLM密钥

# API 地址（通常不需要修改）
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_URL=https://api.siliconflow.cn/v1/embeddings

# ─────────────────────────────────────────────
# Embedding 模型配置（用于向量搜索）
# ─────────────────────────────────────────────
EMBEDDING_MODEL=/
EMBEDDING_DIM=1024

# ─────────────────────────────────────────────
# LLM 模型配置（用于推理）
# ─────────────────────────────────────────────
LLM_MODEL=/
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ─────────────────────────────────────────────
# Chroma 向量数据库配置
# ─────────────────────────────────────────────
# 容器内路径（Docker 挂载：宿主机 /data/chroma -> 容器 /app/chroma）
CHROMA_PATH=/app/chroma/indicators_vector
COLLECTION_NAME=indicators

# ─────────────────────────────────────────────
# Agent 行为配置
# ─────────────────────────────────────────────
# 最大迭代精炼轮次
MAX_ITERATION_ROUNDS=3

# 收敛阈值：Top-1 相似度 > 此值则认为命中
CONVERGENCE_SIMILARITY_THRESHOLD=0.80

# 低置信度阈值：超过此轮次仍未达标，进入低置信度流程
LOW_CONFIDENCE_THRESHOLD=0.60

# 默认 top_k 参数
DEFAULT_TOP_K_THEMES=3
DEFAULT_TOP_K_TEMPLATES=5

# 向量搜索 top_k
VECTOR_SEARCH_TOP_K=20

# Jaccard 相似度阈值：维度两两之间的 Jaccard 均 >= 此值时，提示用户可以全部勾选
JACCARD_SIMILARITY_THRESHOLD=0.5

# ─────────────────────────────────────────────
# 并发控制配置
# ─────────────────────────────────────────────
MAX_CONCURRENT_REQUESTS=10
CONCURRENT_TIMEOUT_SECONDS=5.0

# ─────────────────────────────────────────────
# LLM 调用超时配置（秒）
# ─────────────────────────────────────────────
LLM_CALL_TIMEOUT_SECONDS=60.0
LLM_BATCH_TIMEOUT_SECONDS=310

# ─────────────────────────────────────────────
# LLM 重试配置
# ─────────────────────────────────────────────
# 速率限制重试（5xx 错误）
LLM_MAX_RETRIES_RATE_LIMIT=3
LLM_BASE_DELAY_RATE_LIMIT=5.0
LLM_MAX_DELAY_RATE_LIMIT=60.0

# 超时重试
LLM_MAX_RETRIES_TIMEOUT=2
LLM_BASE_DELAY_TIMEOUT=2.0
LLM_MAX_DELAY_TIMEOUT=10.0

# 服务器错误重试
LLM_MAX_RETRIES_SERVER_ERROR=2
LLM_BASE_DELAY_SERVER_ERROR=1.0
LLM_MAX_DELAY_SERVER_ERROR=8.0

# Schema 错误重试
LLM_MAX_RETRIES_SCHEMA_ERROR=1
LLM_BASE_DELAY_SCHEMA_ERROR=0.5
LLM_MAX_DELAY_SCHEMA_ERROR=2.0

# 认证错误（不重试）
LLM_MAX_RETRIES_AUTH_ERROR=0
LLM_BASE_DELAY_AUTH_ERROR=0.0
LLM_MAX_DELAY_AUTH_ERROR=0.0

# 未知错误
LLM_MAX_RETRIES_UNKNOWN=1
LLM_BASE_DELAY_UNKNOWN=1.0
LLM_MAX_DELAY_UNKNOWN=5.0
